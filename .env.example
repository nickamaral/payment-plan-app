# Chave da Claude API (obrigatória para parsing do anotacoes_mes.txt)
# Obter em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-SEU_TOKEN_AQUI

# Modelo a usar (default: claude-sonnet-4-6)
# Opções: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6
